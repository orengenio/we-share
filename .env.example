# ─── Database (Coolify PostgreSQL service) ────────────────────────────────────
DATABASE_URL="postgresql://weshare:password@postgres:5432/weshare"

# ─── Redis (Coolify Redis service) ───────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://weshare.orengen.io"
JWT_SECRET="generate-with: openssl rand -base64 32"
# Cookie domain for 90-day affiliate attribution
COOKIE_DOMAIN=".orengen.io"

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SETUP_FEE_PRICE_ID="price_setup_997"
STRIPE_MAINTENANCE_PRICE_ID="price_maintenance_247"

# ─── GoHighLevel (GHL) ──────────────────────────────────────────────────────
GHL_API_KEY="your-ghl-api-key"
GHL_LOCATION_ID="your-ghl-location-id"
GHL_WEBHOOK_SECRET="your-ghl-webhook-secret"
GHL_PARTNER_PIPELINE_ID="pipeline-id"
GHL_STAGE_NEW="stage-id-new"
GHL_STAGE_CONTACTED="stage-id-contacted"
GHL_STAGE_APPOINTMENT="stage-id-appointment"
GHL_STAGE_PROPOSAL="stage-id-proposal"
GHL_STAGE_WON="stage-id-won"
GHL_STAGE_LOST="stage-id-lost"
GHL_STAGE_NURTURE="stage-id-nurture"

# ─── Email delivery ───────────────────────────────────────────────────────────
# Provider: mailwizz (recommended) | smtp | ghl (CRM only — poor DMARC alignment)
EMAIL_PROVIDER="mailwizz"
MAILWIZZ_API_URL="https://mail.orengen.io"
MAILWIZZ_API_KEY="your-mailwizz-customer-api-key"
# Alias supported if you already use this name in Coolify:
ORENGEN_PRO_API_KEY="your-mailwizz-customer-api-key"
# Verified sending domain in Mailwizz/SMTP (NOT @orengen.io via GHL — fails DMARC).
EMAIL_FROM="noreply@orengen.io"
EMAIL_REPLY_TO="support@orengen.io"
# Only used when EMAIL_PROVIDER=ghl — must be on crm.orengen.com, not @orengen.io
GHL_EMAIL_FROM="team@crm.orengen.com"

# ─── n8n Webhooks (optional automation) ──────────────────────────────────────
N8N_CLAWBACK_WEBHOOK_URL="https://n8n.orengen.io/webhook/clawback"
N8N_PAYOUT_WEBHOOK_URL="https://n8n.orengen.io/webhook/payout"
N8N_FRAUD_ALERT_WEBHOOK_URL="https://n8n.orengen.io/webhook/fraud"

# ─── Integration API (GHL / n8n checkout attribution) ───────────────────────
WESHARE_API_KEY="generate-with: openssl rand -hex 32"
# Days before a commission becomes payout-eligible (NET-15 default)
COMMISSION_MATURITY_DAYS="15"
# Whether a GHL opportunity hitting Won mints a SETUP_FEE conversion with no
# payment event behind it. Default OFF — commissions follow money; GHL payment
# workflows should call /api/v1/track/purchase instead.
GHL_WON_CREATES_CONVERSION="false"
# Booking link shown on /partners/thanks (GHL calendar). Optional — page falls
# back to "watch your inbox" until set.
NEXT_PUBLIC_PARTNER_CALENDAR_URL=""
# Hero video on /get-started (renders once set; poster optional). Generate via
# Veo with the brief in artifacts/weshare-launch/media/veo-hero-brief.md, host
# the mp4 in the GHL media library or /public, paste the URL here + redeploy.
NEXT_PUBLIC_HERO_VIDEO_URL=""
NEXT_PUBLIC_HERO_VIDEO_POSTER=""

# ─── Admin Bootstrap ──────────────────────────────────────────────────────────
ADMIN_EMAILS="sales@orengen.io"

# ─── SMTP (transactional email — UseSend / MailWizz / any SMTP relay) ─────────
SMTP_HOST="mail.orengen.io"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@orengen.io"
SMTP_PASS="your-smtp-password"

# ─── Google Gemini (AI features) ──────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.0-flash"
